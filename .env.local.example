# Azure Configuration
# Required: set these before running terraform
ARM_SUBSCRIPTION_ID=your-subscription-id
ARM_TENANT_ID=your-tenant-id

# Optional: if using service principal auth (otherwise use `az login`)
# ARM_CLIENT_ID=your-client-id
# ARM_CLIENT_SECRET=your-client-secret

# GitHub Container Registry (for pushing custom images)
GHCR_USERNAME=your-github-username
GHCR_TOKEN=your-github-pat

# Project settings (defaults work for most cases)
# TF_VAR_environment=dev
# TF_VAR_region=southcentralus
# TF_VAR_location=ussc
